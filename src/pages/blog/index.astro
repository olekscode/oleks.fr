---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogPreview from '../../components/BlogPreview.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.date - a.data.date);
---
<PageLayout title="Blog" description="Writing that does not belong in the formal publications list: notes, reflections, and technical essays.">
  <BlogPreview items={posts} />
</PageLayout>
