---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/dates.js';
const { title, description, date, updatedDate, tags = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="content-page page-wrap">
    <header class="page-header">
      <p class="kicker">Blog</p>
      <h1>{title}</h1>
      <p class="page-intro">{description}</p>
      <p class="meta-line">{formatDate(date)}{updatedDate ? ` · Updated ${formatDate(updatedDate)}` : ''}</p>
      {tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
    </header>
    <slot />
  </article>
</BaseLayout>
